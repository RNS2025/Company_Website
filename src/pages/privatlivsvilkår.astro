---
import CinematicLayout from "../layouts/CinematicLayout.astro";
import CinematicNav from "../components/cinematic/CinematicNav.astro";
import CinematicFooter from "../components/cinematic/CinematicFooter.astro";

import { useTranslations, getLocaleLink } from "../data/locales/i18n";

const lastUpdated = "7. august 2025";
const contactEmail = "contact@rnsapps.dk";
const locale = Astro.currentLocale || 'da';
const t = useTranslations(locale);
---

<CinematicLayout
  title="Privatlivsvilkår"
  description="Privatlivspolitik for RNS APPS — hvordan vi indsamler, bruger og beskytter dine personoplysninger."
>
  <CinematicNav />

  <article class="legal pt-32">
    <header class="legal__header">
      <p class="legal__eyebrow">Juridisk</p>
      <h1 class="legal__title">Privatlivsvilkår</h1>
      <p class="legal__meta">Sidst opdateret: {lastUpdated}</p>
      <p class="legal__intro">
        Denne privatlivspolitik beskriver, hvordan RNS-Apps ApS indsamler, bruger og
        beskytter personoplysninger, når du besøger vores website eller bruger vores
        tjenester. Vi behandler data i overensstemmelse med gældende
        databeskyttelseslovgivning, herunder GDPR.
      </p>
    </header>

    <div class="legal__body">
      <section class="legal__section" id="dataansvarlig">
        <h2>1. Dataansvarlig</h2>
        <p>
          <strong>RNS-Apps ApS</strong> (herefter "vi", "os" eller "virksomheden") er
          dataansvarlig for de personoplysninger, vi behandler via vores website og
          relaterede tjenester.
        </p>
        <p>
          Kontakt: <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
        </p>
      </section>

      <section class="legal__section" id="hvad-indsamler-vi">
        <h2>2. Hvilke oplysninger indsamler vi?</h2>
        <p>Vi kan indsamle følgende typer af oplysninger:</p>
        <ul>
          <li><strong>Kontaktoplysninger</strong> — navn, e-mail og telefonnummer, når du kontakter os via formular eller e-mail.</li>
          <li><strong>Kommunikation</strong> — indholdet af henvendelser og korrespondance med os.</li>
          <li><strong>Tekniske data</strong> — IP-adresse, browsertype, enhedstype, besøgte sider og tidspunkt for besøg (via cookies og analyseværktøjer).</li>
          <li><strong>App-relaterede data</strong> — for vores mobilapps gælder særskilte vilkår; se afsnit om datasletning nedenfor.</li>
        </ul>
      </section>

      <section class="legal__section" id="formaal">
        <h2>3. Formål med behandlingen</h2>
        <p>Vi behandler personoplysninger til følgende formål:</p>
        <ul>
          <li>At besvare henvendelser og levere vores tjenester</li>
          <li>At administrere kundeforhold og projekter</li>
          <li>At forbedre website, sikkerhed og brugeroplevelse</li>
          <li>At overholde juridiske forpligtelser</li>
        </ul>
        <p>
          Vi bruger ikke dine oplysninger til markedsføring uden dit samtykke, medmindre
          du allerede er kunde og vi informerer om lignende ydelser — og du altid kan
          framelde dig.
        </p>
      </section>

      <section class="legal__section" id="retsgrundlag">
        <h2>4. Retsgrundlag</h2>
        <p>Vi behandler personoplysninger på baggrund af:</p>
        <ul>
          <li><strong>Kontraktopfyldelse</strong> — når behandlingen er nødvendig for at levere en aftalt ydelse</li>
          <li><strong>Legitim interesse</strong> — f.eks. drift og sikkerhed af vores website</li>
          <li><strong>Samtykke</strong> — hvor det er påkrævet, f.eks. visse cookies</li>
          <li><strong>Retlig forpligtelse</strong> — når loven kræver det</li>
        </ul>
      </section>

      <section class="legal__section" id="opbevaring">
        <h2>5. Opbevaring</h2>
        <p>
          Vi opbevarer personoplysninger, så længe det er nødvendigt for de formål,
          de er indsamlet til — typisk så længe et kundeforhold består, plus den
          periode loven kræver for bogføring og dokumentation.
        </p>
        <p>
          Tekniske logdata opbevares kortere, medmindre they er nødvendige af
          sikkerhedsmæssige årsager.
        </p>
      </section>

      <section class="legal__section" id="deling">
        <h2>6. Deling med tredjeparter</h2>
        <p>
          Vi sælger ikke dine personoplysninger. Vi kan dele data med betroede
          databehandlere, der hjælper os med drift — f.eks. hosting, e-mail eller
          analyse — under databehandleraftaler der sikrer tilstrækkelig beskyttelse.
        </p>
        <p>
          Oplysninger kan også videregives, hvis loven kræver det, eller for at
          beskytte vores rettigheder og sikkerhed.
        </p>
      </section>

      <section class="legal__section" id="sikkerhed">
        <h2>7. Sikkerhed</h2>
        <p>
          Vi implementerer passende tekniske og organisatoriske foranstaltninger for
          at beskytte personoplysninger. Ingen overførsel via internettet er dog
          100 % sikker, og vi kan ikke garantere absolut sikkerhed.
        </p>
      </section>

      <section class="legal__section" id="dine-rettigheder">
        <h2>8. Dine rettigheder</h2>
        <p>Under GDPR har du ret til at:</p>
        <ul>
          <li>Få indsigt i de oplysninger, vi har om dig</li>
          <li>Få rettet unøjagtige oplysninger</li>
          <li>Få slettet oplysninger ("retten til at blive glemt")</li>
          <li>Begrænse eller gøre indsigelse mod behandling</li>
          <li>Modtage dine data i et struktureret format (dataportabilitet)</li>
          <li>Tilbagekalde samtykke, hvor behandlingen bygger på samtykke</li>
        </ul>
        <p>
          Kontakt os på <a href={`mailto:${contactEmail}`}>{contactEmail}</a> for at
          udøve dine rettigheder. Du kan også klage til Datatilsynet.
        </p>
      </section>

      <section class="legal__section" id="datasletning">
        <h2>9. Sletning af app-data</h2>
        <p>
          Bruger du en af vores iOS- eller mobilapps, kan du anmode om sletning af
          din konto og tilknyttede data via vores datasletningsside:
        </p>
        <p>
          <a href={getLocaleLink("/data-sletning/", locale)}>Anmodning om datasletning</a>
        </p>
        <p>
          For SMASH Padelcenter-appen findes en dedikeret side:
          <a href={getLocaleLink("/smash-padelcenter/data-sletning/", locale)}>Datasletning (SMASH)</a>.
        </p>
        <p>
          Du kan også skrive direkte til
          <a href={`mailto:${contactEmail}`}>{contactEmail}</a>.
        </p>
      </section>

      <section class="legal__section" id="cookies">
        <h2>10. Cookies og analyse</h2>
        <p>
          Vores website kan bruge cookies og lignende teknologier til drift,
          statistik og forbedring af oplevelsen. Du kan administrere cookies i din
          browsers indstillinger.
        </p>
        <p>
          We kan anvende analyseværktøjer (f.eks. Google Analytics) til at forstå,
          hvordan siden bruges. Disse værktøjer kan indsamle anonymiserede eller
          pseudonymiserede brugsdata.
        </p>
      </section>

      <section class="legal__section" id="born">
        <h2>11. Børn</h2>
        <p>
          Vour tjenester er ikke rettet mod personer under 13 år. Vi indsamler ikke
          bevidst personoplysninger fra børn. Kontakt os, hvis du mener, vi har
          modtaget sådanne oplysninger.
        </p>
      </section>

      <section class="legal__section" id="links">
        <h2>12. Links til andre websites</h2>
        <p>
          Vores website kan indeholde links til eksterne sider. Vi er ikke
          ansvarlige for disse sites' privatlivspraksis. Vi anbefaler, at du læser
          deres privatlivspolitikker.
        </p>
      </section>

      <section class="legal__section" id="aendringer">
        <h2>13. Ændringer</h2>
        <p>
          Vi kan opdatere denne privatlivspolitik fra tid til anden. Væsentlige
          ændringer offentliggøres på denne side med en opdateret dato. Vi opfordrer
          dig til at gennemgå politikken jævnligt.
        </p>
      </section>

      <section class="legal__section" id="kontakt">
        <h2>14. Kontakt</h2>
        <p>
          Spørgsmål til denne privatlivspolitik kan rettes til:
        </p>
        <p>
          <strong>RNS-Apps ApS</strong><br />
          E-mail: <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
        </p>
      </section>
    </div>
  </article>

  <CinematicFooter />
</CinematicLayout>

<style>
  .legal {
    max-width: 42rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .legal__header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .legal__eyebrow {
    font-family: 'JUSTSans', system-ui, sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #ff6941;
    margin-bottom: 0.75rem;
  }

  .legal__title {
    font-family: 'Geszog', system-ui, sans-serif;
    font-size: clamp(2rem, 5vw, 2.75rem);
    line-height: 1.1;
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .legal__meta {
    font-family: 'JUSTSans', system-ui, sans-serif;
    font-size: 0.9rem;
    color: #d1d5db;
    margin-bottom: 1.25rem;
  }

  .legal__intro {
    font-family: 'JUSTSans', system-ui, sans-serif;
    font-size: 1.05rem;
    line-height: 1.7;
    color: #d1d5db;
  }

  .legal__section {
    margin-bottom: 2.25rem;
  }

  .legal__section h2 {
    font-family: 'Quano', system-ui, sans-serif;
    font-size: 1.35rem;
    line-height: 1.25;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .legal__section p {
    font-family: 'JUSTSans', system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    color: #d1d5db;
    margin-bottom: 0.85rem;
  }

  .legal__section p:last-child {
    margin-bottom: 0;
  }

  .legal__section ul {
    margin: 0.5rem 0 1rem;
    padding-left: 1.25rem;
    list-style: disc;
  }

  .legal__section li {
    font-family: 'JUSTSans', system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.7;
    color: #d1d5db;
    margin-bottom: 0.5rem;
  }

  .legal__section li strong {
    color: #fff;
    font-weight: 600;
  }

  .legal__section a {
    color: #ff6941;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s ease;
  }

  .legal__section a:hover {
    color: #e05030;
  }
</style>
