---
import CinematicLayout from "../layouts/CinematicLayout.astro";
import CinematicNav from "../components/cinematic/CinematicNav.astro";
import CinematicFooter from "../components/cinematic/CinematicFooter.astro";
import VideoBackground from "../components/ui/VideoBackground.astro";
import FadeIn from "../components/animations/FadeIn.astro";
import Card from "../components/ui/Card.astro";
import { Trash2, Mail, AlertCircle } from "lucide-astro";
import { useTranslations, getLocaleLink } from "../data/locales/i18n";

const locale = Astro.currentLocale || 'da';
const t = useTranslations(locale);
const { dataSletning } = t;
---

<CinematicLayout title={dataSletning.metaTitle} noindex={true}>
  <CinematicNav />

  <section class="relative min-h-[45vh] flex items-center justify-center pt-28 overflow-hidden">
    <VideoBackground
      src="/video/abstract-tech.mp4"
      overlay="heavy"
      class="opacity-15"
    />

    <div class="relative z-10 container mx-auto px-6 text-center">
      <FadeIn>
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-primary-500/20 mb-6">
          <Trash2 size={32} class="text-primary-500" />
        </div>
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tighter mb-4 text-white">
          {dataSletning.title}<span class="bg-gradient-to-r from-primary-500 to-primary-600 text-transparent bg-clip-text">{dataSletning.titleHighlight}</span>
        </h1>
        <p class="text-xl text-gray-300 mt-2 max-w-2xl mx-auto font-medium">
          {dataSletning.subtitle}
        </p>
      </FadeIn>
    </div>
  </section>

  <section class="container mx-auto px-6 py-20">
    <FadeIn>
      <div class="max-w-2xl mx-auto">
        <Card glass={true}>
          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-3">
            <Mail size={24} class="text-primary-500" />
            {dataSletning.howToTitle}
          </h2>
          <p class="mb-6 text-gray-300 leading-relaxed">
            {dataSletning.howToText}
          </p>
          <div class="text-center mb-8">
            <a
              href="mailto:contact@rnsapps.dk?subject=Anmodning%20om%20sletning%20af%20brugerdata"
              class="inline-flex items-center gap-2 bg-gradient-to-r from-primary-500 to-primary-600 hover:shadow-lg hover:shadow-primary-500/30 hover:scale-105 text-white font-bold py-3.5 px-8 rounded-full transition-all duration-300"
            >
              <Mail size={20} />
              {dataSletning.btnText}
            </a>
          </div>

          <div class="mt-8 pt-8 border-t border-white/10">
            <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-3">
              <AlertCircle size={22} class="text-yellow-500" />
              {dataSletning.importantTitle}
            </h3>
            <ul class="space-y-4 text-gray-300">
              {dataSletning.bullets.map((bullet, idx) => (
                <li class="flex items-start gap-3">
                  <span class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-500/20 text-primary-500 flex items-center justify-center text-sm font-bold mt-0.5">{idx + 1}</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </div>

          <p class="mt-8 pt-6 border-t border-white/10 text-center text-gray-500 text-sm">
            {dataSletning.smashText1}<strong class="text-gray-300">SMASH Padelcenter</strong>{dataSletning.smashText2}
            <a href={getLocaleLink("/smash-padelcenter/data-sletning/", locale)} class="text-primary-500 hover:underline">{dataSletning.smashLinkText}</a>.
          </p>
        </Card>
      </div>
    </FadeIn>
  </section>

  <CinematicFooter />
</CinematicLayout>
