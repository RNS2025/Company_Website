---
import CinematicLayout from '../layouts/CinematicLayout.astro';
import CinematicNav from '../components/cinematic/CinematicNav.astro';
import InteractiveField from '../components/cinematic/InteractiveField.astro';
import HeroCinematic from '../components/cinematic/HeroCinematic.astro';
import ServicesSection from '../components/cinematic/ServicesSection.astro';
import ProjectsCarousel from '../components/cinematic/ProjectsCarousel.astro';
import AboutSection from '../components/cinematic/AboutSection.astro';
import CinematicFooter from '../components/cinematic/CinematicFooter.astro';
import ProjectPlanner from '../components/forms/ProjectPlanner.astro';
import { useTranslations } from '../data/locales/i18n';

const locale = Astro.currentLocale || 'da';
const t = useTranslations(locale);
const { finale, contactSection } = t;

const title = locale === 'en' ? 'Home' : 'Forside';
const description = locale === 'en'
  ? 'Tailored software and AI solutions with continuous operations — RNS APPS is your long-term technical partner.'
  : 'Skræddersyet software og AI-løsninger med løbende drift — RNS APPS er jeres langsigtede tekniske partner.';
---

<CinematicLayout
  title={title}
  description={description}
>
  <div id="scroll-progress" aria-hidden="true"></div>

  <InteractiveField />
  <CinematicNav />

  <div id="content">
    <HeroCinematic />
    <ServicesSection />
    <ProjectsCarousel />
    <AboutSection />
  </div>

  <section class="cinematic-station cinematic-contact" id="kontakt" data-cinematic-station>
    <div class="cinematic-contact__finale">
      <p>{finale.label}</p>
      <h2>{finale.headline}</h2>
    </div>
    <div class="cinematic-contact__inner">
      <div class="cinematic-contact__planner-header">
        <h3>{contactSection.title}</h3>
        <p>{contactSection.description}</p>
      </div>
      <ProjectPlanner recipientEmail="contact@rnsapps.dk" />
    </div>
  </section>

  <CinematicFooter />
</CinematicLayout>

<script>
  import '../scripts/cinematic-scroll.js';
</script>
