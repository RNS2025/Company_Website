---
import Layout from "../layouts/Layout.astro";
import StoryBlock from "../components/story/StoryBlock.astro";
import ContactForm from "../components/forms/ContactForm.astro";
import Button from "../components/ui/Button.astro";
---

<Layout title="Forside">

    <!-- ░░ SCROLL-PROGRESS BAR ░░ -->
    <div id="scroll-progress" aria-hidden="true"></div>

    <!-- ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
    <!-- KAPITEL 0 — Intro-hilsen                            -->
    <!-- ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
    <StoryBlock id="intro" align="center">
        <p class="greeting-wave">Hej!</p>
        <h1 class="heading-xl">
            Velkommen til<br class="hidden sm:block" />
            RNS APPS
        </h1>
        <p class="heading-question">
            Må vi introducere os selv?
        </p>
        <div class="scroll-hint" aria-label="Scroll ned">
            <span>Scroll</span>
            <div class="scroll-line"></div>
        </div>
    </StoryBlock>

    <!-- ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
    <!-- KAPITEL 1 — Hvem er vi?                             -->
    <!-- ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
    <StoryBlock id="hvem-er-vi" align="left" chapter="01">
        <h2 class="heading-lg">
            Vi hedder <span class="hl">Luu</span> og <span class="hl">Jens</span>
        </h2>
        <p class="body-lead">
            - og vi står bag <span class="hl">RNS Apps</span>.
        </p>
        <p class="body-text">
            Vi vil gerne lave applikationer og digitale systemer
            der er til at forstå&nbsp;- også selvom man ikke har
            nogen teknisk baggrund.
        </p>
    </StoryBlock>

    <!-- ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
    <!-- KAPITEL 2 — Vores filosofi                          -->
    <!-- ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
    <StoryBlock id="filosofi" align="center" chapter="02">
        <h2 class="heading-lg">
            Ligesom alle gode<br />
            <span class="hl">eventyr</span> startede det i det lokale padelcenter
        </h2>
        <p class="body-text max-w-2xl mx-auto">
            Vores ugentlige morgenturnering manglede en turneringsapp der kunne rumme de mange deltagere.
            Navnet på turneringen var <span class="hl">R</span>ise '<span class="hl">n</span> <span class="hl">S</span>hine.
        </p>
    </StoryBlock>

    <!-- ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
    <!-- KAPITEL 3 — Hvad vi har lavet                       -->
    <!-- ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
    <section class="chapter-3" data-chapter3>

        <!-- Intro-tekst -->
        <div class="ch3-text" data-ch3-text>
            <p class="ch3-chapter-label">03</p>
            <p class="ch3-intro">
                Siden da har vi været så heldige at få muligheden
                for at udvikle mange forskellige ting...
            </p>
        </div>

        <!-- Spredte ord -->
        <span class="cloud-word" style="--rot:-6deg; --delay:0.35s; top:22%; left:6%;">Klubapp</span>
        <span class="cloud-word cw-accent" style="--rot:3deg; --delay:0.6s; top:18%; right:8%;">Betalingsløsning</span>
        <span class="cloud-word" style="--rot:-3deg; --delay:0.85s; top:80%; left:18%;">Turneringssystem</span>
        <span class="cloud-word cw-accent" style="--rot:7deg; --delay:1.1s; top:70%; right:12%;">Digitalt scorekort til nichegolf</span>
        <span class="cloud-word" style="--rot:-9deg; --delay:1.3s; top:20%; left:40%;">Baneoversigt</span>
    </section>

    <!-- ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
    <!-- KAPITEL 4 — Vores tilgang                           -->
    <!-- ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
    <section class="chapter-4" data-chapter4>
        <div class="ch4-inner">

            <p class="ch4-label">04</p>

            <p class="ch4-pretext">Vi tror på</p>

            <div class="ch4-pillars">
                <p class="ch4-pillar" style="--i:0">Tæt samarbejde<span class="ch4-dot">.</span></p>
                <p class="ch4-pillar ch4-pillar--accent" style="--i:1">Hurtig support<span class="ch4-dot">.</span></p>
                <p class="ch4-pillar" style="--i:2">Løsninger der vokser<span class="ch4-dot">.</span></p>
            </div>

            <p class="ch4-coda">For de bedste systemer føles ofte simple.</p>

        </div>
    </section>

    <!-- ░░ KONTAKTFORMULAR ░░ -->
    <section class="contact-snap-section">
        <div class="max-w-3xl mx-auto px-6 py-28">
            <ContactForm
                title="Har du en idé, et problem eller bare en masse Excel-ark?"
                description="Så tager vi gerne en kop kaffe og ser på det sammen."
            />
        </div>
    </section>

</Layout>

<!-- ─────────────────────────────────────────────────────── -->
<!--  SCROLL-PROGRESS SCRIPT                                 -->
<!-- ─────────────────────────────────────────────────────── -->
<script>
    (() => {
        const bar = document.getElementById('scroll-progress');
        if (!bar) return;
        const update = () => {
            const scrolled = window.scrollY;
            const total = document.documentElement.scrollHeight - window.innerHeight;
            bar.style.transform = `scaleX(${total > 0 ? scrolled / total : 0})`;
        };
        window.addEventListener('scroll', update, { passive: true });
        update();
    })();

    // ── Kapitel 4 — manifest animation ────────────────────
    (() => {
        const init = () => {
            const section = document.querySelector<HTMLElement>('[data-chapter4]');
            if (!section) return;
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            section.classList.add('is-entered');
                        } else {
                            section.classList.remove('is-entered');
                        }
                    });
                },
                { threshold: 0.45 }
            );
            observer.observe(section);
        };
        document.addEventListener('astro:page-load', init);
        if (document.readyState !== 'loading') init();
    })();
    (() => {
        const init = () => {
            const section = document.querySelector<HTMLElement>('[data-chapter3]');
            if (!section) return;

            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            section.classList.add('is-entered');
                        } else {
                            section.classList.remove('is-entered');
                        }
                    });
                },
                { threshold: 0.45 }
            );

            observer.observe(section);
        };

        document.addEventListener('astro:page-load', init);
        if (document.readyState !== 'loading') init();
    })();
</script>

<style>
    /* ── Scroll-progress bar ─────────────────────────────── */
    #scroll-progress {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(90deg, #FF6941, #F2865F);
        transform: scaleX(0);
        transform-origin: left;
        z-index: 9999;
        transition: transform 0.1s linear;
    }

    /* ── Hilsen / wave ───────────────────────────────────── */
    .greeting-wave {
        font-family: 'JUSTSans', sans-serif;
        font-size: clamp(1.25rem, 3vw, 1.75rem);
        color: #FF6941;
        letter-spacing: 0.06em;
        margin-bottom: 1.25rem;
    }

    /* ── Stor overskrift (h1) ────────────────────────────── */
    .heading-xl {
        font-family: 'Geszog', system-ui, sans-serif;
        font-size: clamp(3rem, 9vw, 7.5rem);
        line-height: 1.05;
        font-weight: 900;
        letter-spacing: -0.02em;
        color: #2A2A2A;
        margin-bottom: 2rem;
    }

    /* ── Spørgsmål under h1 ──────────────────────────────── */
    .heading-question {
        font-family: 'Quano', system-ui, sans-serif;
        font-size: clamp(1.25rem, 3vw, 2rem);
        color: #314245;
        opacity: 0.65;
        font-style: italic;
        margin-bottom: 4rem;
    }

    /* ── Mellemstor overskrift (h2) ──────────────────────── */
    .heading-lg {
        font-family: 'Quano', system-ui, sans-serif;
        font-size: clamp(2rem, 6vw, 5rem);
        line-height: 1.1;
        color: #2A2A2A;
        margin-bottom: 1.25rem;
    }

    /* ── Lead-sætning ────────────────────────────────────── */
    .body-lead {
        font-family: 'Quano', system-ui, sans-serif;
        font-size: clamp(1.5rem, 3.5vw, 2.25rem);
        color: #314245;
        margin-bottom: 1.75rem;
    }

    /* ── Brødtekst ───────────────────────────────────────── */
    .body-text {
        font-family: 'JUSTSans', system-ui, sans-serif;
        font-size: clamp(1rem, 2vw, 1.3rem);
        line-height: 1.75;
        color: #314245;
        opacity: 0.8;
        max-width: 38rem;
        margin-bottom: 2rem;
    }

    /* ── Orange highlight ────────────────────────────────── */
    .hl {
        color: #FF6941;
    }

    /* ── CTA-række ───────────────────────────────────────── */
    .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: center;
        margin-top: 2.5rem;
    }

    /* ── Scroll-hint animation ───────────────────────────── */
    .scroll-hint {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        opacity: 0.35;
        margin-top: 1rem;
    }

    .scroll-hint span {
        font-family: 'JUSTSans', sans-serif;
        font-size: 0.7rem;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: #2A2A2A;
    }

    .scroll-line {
        width: 1px;
        height: 3rem;
        background: linear-gradient(to bottom, #FF6941, transparent);
        animation: scrollPulse 1.8s ease-in-out infinite;
        transform-origin: top;
    }

    @keyframes scrollPulse {
        0%   { transform: scaleY(0); opacity: 0; }
        40%  { transform: scaleY(1); opacity: 1; }
        100% { transform: scaleY(1); opacity: 0; }
    }

    /* ── Kontaktsektion snap ─────────────────────────────── */
    .contact-snap-section {
        scroll-snap-align: start;
        min-height: 100svh;
        display: flex;
        align-items: center;
        background: #F2F2F3;
    }

    /* ══ KAPITEL 4 — Manifest ════════════════════════════════ */
    .chapter-4 {
        scroll-snap-align: start;
        scroll-snap-stop: always;
        position: relative;
        height: 100svh;
        display: flex;
        align-items: center;
        background: #2A2A2A;
        overflow: hidden;
    }

    /* Subtil tekstur — store lyse bogstaver bag alt */
    .chapter-4::before {
        content: 'RNS';
        position: absolute;
        bottom: -0.15em;
        right: -0.05em;
        font-family: 'Geszog', system-ui, sans-serif;
        font-size: clamp(12rem, 30vw, 22rem);
        line-height: 1;
        color: #F2F2F3;
        opacity: 0.03;
        user-select: none;
        pointer-events: none;
    }

    .ch4-inner {
        width: 100%;
        max-width: 72rem;
        margin: 0 auto;
        padding: 0 2rem;
    }

    /* Kapitel-label */
    .ch4-label {
        font-family: 'JUSTSans', sans-serif;
        font-size: 0.75rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #FF6941;
        margin-bottom: 1.5rem;
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.5s ease 0s, transform 0.5s ease 0s;
    }

    /* "Vi tror på" */
    .ch4-pretext {
        font-family: 'JUSTSans', sans-serif;
        font-size: clamp(1rem, 2vw, 1.3rem);
        color: #EAE9E9;
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.6s ease 0.1s, transform 0.6s ease 0.1s;
        margin-bottom: 1.5rem;
        letter-spacing: 0.05em;
    }

    /* De tre store linjer */
    .ch4-pillars {
        display: flex;
        flex-direction: column;
        gap: 0.1em;
        margin-bottom: 3rem;
    }

    .ch4-pillar {
        font-family: 'Geszog', system-ui, sans-serif;
        font-size: clamp(2.2rem, 7vw, 6rem);
        line-height: 1.05;
        color: #F2F2F3;
        opacity: 0;
        transform: translateX(-40px);
        transition:
            opacity 0.75s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.75s cubic-bezier(0.16, 1, 0.3, 1);
        transition-delay: calc(0.25s + var(--i) * 0.18s);
    }

    .ch4-pillar--accent {
        color: #FF6941;
    }

    .ch4-dot {
        color: #FF6941;
    }

    /* Afsluttende kursiv */
    .ch4-coda {
        font-family: 'Quano', system-ui, sans-serif;
        font-size: clamp(1rem, 2.2vw, 1.5rem);
        font-style: italic;
        color: #EAE9E9;
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.7s ease 0.85s, transform 0.7s ease 0.85s;
        border-left: 2px solid #FF6941;
        padding-left: 1rem;
    }

    /* ── Synlig tilstand ─────────────────────────────────── */
    .chapter-4.is-entered .ch4-label,
    .chapter-4.is-entered .ch4-pretext,
    .chapter-4.is-entered .ch4-pillar,
    .chapter-4.is-entered .ch4-coda {
        opacity: 1;
        transform: none;
    }

    /* ══ KAPITEL 3 — Ordsky ══════════════════════════════════ */
    .chapter-3 {
        scroll-snap-align: start;
        scroll-snap-stop: always;
        position: relative;
        height: 100svh;
        overflow: hidden;
        background: #F2F2F3;
    }

    /* Intro-tekst */
    .ch3-text {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        text-align: center;
        z-index: 2;
        opacity: 0;
        translate: 0 30px;
        transition: opacity 0.85s cubic-bezier(0.16, 1, 0.3, 1),
                    translate 0.85s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .chapter-3.is-entered .ch3-text {
        opacity: 1;
        translate: 0 0;
    }

    .ch3-chapter-label {
        font-family: 'JUSTSans', sans-serif;
        font-size: 0.75rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #FF6941;
        margin-bottom: 1rem;
    }

    .ch3-intro {
        font-family: 'Quano', system-ui, sans-serif;
        font-size: clamp(1.4rem, 3.5vw, 2.5rem);
        line-height: 1.3;
        color: #2A2A2A;
        max-width: 42rem;
    }

    /* ── Spredte ord ─────────────────────────────────────── */
    .cloud-word {
        position: absolute;
        font-family: 'Geszog', system-ui, sans-serif;
        font-size: clamp(1.4rem, 3vw, 2.4rem);
        color: #314245;
        opacity: 0;
        transform: translateY(25px) rotate(var(--rot, 0deg));
        transition: opacity 0.75s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.75s cubic-bezier(0.16, 1, 0.3, 1);
        transition-delay: var(--delay, 0s);
        white-space: nowrap;
        user-select: none;
    }

    .cloud-word.cw-accent {
        color: #FF6941;
        font-size: clamp(1.2rem, 2.5vw, 2rem);
    }

    .cloud-word.cw-muted {
        color: #314245;
        opacity: 0;
        font-size: clamp(1rem, 2vw, 1.6rem);
    }

    .chapter-3.is-entered .cloud-word {
        opacity: 0.18;
        transform: translateY(0) rotate(var(--rot, 0deg));
    }

    .chapter-3.is-entered .cloud-word.cw-accent {
        opacity: 0.55;
    }

    .chapter-3.is-entered .cloud-word.cw-muted {
        opacity: 0.1;
    }
</style>

