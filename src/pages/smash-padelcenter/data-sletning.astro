---
import CinematicLayout from "../../layouts/CinematicLayout.astro";
import CinematicNav from "../../components/cinematic/CinematicNav.astro";
import CinematicFooter from "../../components/cinematic/CinematicFooter.astro";
import VideoBackground from "../../components/ui/VideoBackground.astro";
import FadeIn from "../../components/animations/FadeIn.astro";
import Card from "../../components/ui/Card.astro";
import { Trash2, Mail, AlertCircle, Smartphone } from "lucide-astro";
import { useTranslations } from "../../data/locales/i18n";

const locale = Astro.currentLocale || 'da';
const t = useTranslations(locale);
const { smashDataSletning } = t;
---

<CinematicLayout title={smashDataSletning.metaTitle} noindex={true}>
  <CinematicNav />

  <!-- Hero Section with Video Background -->
  <section
    class="relative min-h-[45vh] flex items-center justify-center pt-28 overflow-hidden"
  >
    <VideoBackground src="/video/abstract-tech.mp4" overlay="heavy" class="opacity-15" />

    <div class="relative z-10 container mx-auto px-6 text-center">
      <FadeIn>
        <div
          class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-primary-500/20 mb-6"
        >
          <Trash2 size={32} class="text-primary-500" />
        </div>
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tighter mb-4 text-white">
          {smashDataSletning.title}<span
            class="bg-gradient-to-r from-primary-500 to-primary-600 text-transparent bg-clip-text"
            >{smashDataSletning.titleHighlight}</span
          >
        </h1>
        <p class="text-xl text-gray-300 mt-2 max-w-2xl mx-auto font-medium">
          {smashDataSletning.subtitle}
        </p>
      </FadeIn>
    </div>
  </section>

  <section class="container mx-auto px-6 py-20">
    <FadeIn>
      <div class="max-w-2xl mx-auto">
        <Card glass={true}>
          <!-- App Information Section -->
          <div class="mb-8 p-6 bg-white/5 rounded-xl border border-white/10">
            <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-3">
              <Smartphone size={24} class="text-primary-500" />
              {smashDataSletning.appInfoTitle}
            </h2>
            <div class="space-y-3 text-gray-300">
              <p>
                <span class="text-white font-semibold">{smashDataSletning.appNameLabel}</span> SMASH Padelcenter
              </p>
              <p>
                <span class="text-white font-semibold">{smashDataSletning.appIdLabel}</span> dk.rnsapps.smash
              </p>
              <p>
                <span class="text-white font-semibold">{smashDataSletning.companyLabel}</span> RNS Apps
              </p>
            </div>
          </div>

          <h2 class="text-2xl font-bold text-white mb-4 flex items-center gap-3">
            <Mail size={24} class="text-primary-500" />
            {smashDataSletning.howToTitle}
          </h2>
          <p class="mb-6 text-gray-300 leading-relaxed" set:html={smashDataSletning.howToText}></p>
          
          <div class="text-center mb-8">
            <a
              href="mailto:jens@rnsapps.dk?subject=Anmodning%20om%20sletning%20af%20brugerdata%20-%20SMASH%20Padelcenter%20(dk.rnsapps.smash)"
              class="inline-flex items-center gap-2 bg-gradient-to-r from-primary-500 to-primary-600 hover:shadow-lg hover:shadow-primary-500/30 hover:scale-105 text-white font-bold py-3.5 px-8 rounded-full transition-all duration-300"
            >
              <Mail size={20} />
              {smashDataSletning.btnText}
            </a>
          </div>

          <div class="mt-10 pt-8 border-t border-white/10">
            <h3
              class="text-xl font-semibold text-white mb-4 flex items-center gap-3"
            >
              <AlertCircle size={22} class="text-yellow-500" />
              {smashDataSletning.importantTitle}
            </h3>
            <ul class="space-y-4 text-gray-300">
              {smashDataSletning.bullets.map((bullet, idx) => (
                <li class="flex items-start gap-3">
                  <span
                    class="flex-shrink-0 w-6 h-6 rounded-full bg-primary-500/20 text-primary-500 flex items-center justify-center text-sm font-bold mt-0.5"
                    >{idx + 1}</span
                  >
                  <span set:html={bullet}></span>
                </li>
              ))}
            </ul>
          </div>

          <div
            class="mt-8 pt-6 border-t border-white/10 text-center text-gray-500 text-sm"
          >
            <p class="mt-1" set:html={smashDataSletning.footerText}></p>
          </div>
        </Card>
      </div>
    </FadeIn>
  </section>

  <CinematicFooter />
</CinematicLayout>
