---
import CinematicLayout from "../../layouts/CinematicLayout.astro";
import CinematicNav from "../../components/cinematic/CinematicNav.astro";
import CinematicFooter from "../../components/cinematic/CinematicFooter.astro";
import { useTranslations, getLocaleLink } from "../../data/locales/i18n";

const lastUpdated = "August 7, 2025";
const contactEmail = "contact@rnsapps.dk";
const locale = Astro.currentLocale || 'da';
const t = useTranslations(locale);
---

<CinematicLayout
  title="Privacy Policy"
  description="Privacy Policy for RNS APPS — how we collect, use, and protect your personal data."
>
  <CinematicNav />

  <article class="legal pt-32">
    <header class="legal__header">
      <p class="legal__eyebrow">Legal</p>
      <h1 class="legal__title">Privacy Policy</h1>
      <p class="legal__meta">Last updated: {lastUpdated}</p>
      <p class="legal__intro">
        This privacy policy describes how RNS-Apps ApS collects, uses, and
        protects personal data when you visit our website or use our
        services. We process data in accordance with applicable
        data protection legislation, including the GDPR.
      </p>
    </header>

    <div class="legal__body">
      <section class="legal__section" id="dataansvarlig">
        <h2>1. Data Controller</h2>
        <p>
          <strong>RNS-Apps ApS</strong> (hereinafter "we", "us", or "the company") is the
          data controller for the personal data we process via our website and
          related services.
        </p>
        <p>
          Contact: <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
        </p>
      </section>

      <section class="legal__section" id="hvad-indsamler-vi">
        <h2>2. What information do we collect?</h2>
        <p>We may collect the following types of information:</p>
        <ul>
          <li><strong>Contact information</strong> — name, email, and phone number when you contact us via form or email.</li>
          <li><strong>Communication</strong> — the content of inquiries and correspondence with us.</li>
          <li><strong>Technical data</strong> — IP address, browser type, device type, visited pages, and time of visit (via cookies and analytics tools).</li>
          <li><strong>App-related data</strong> — for our mobile apps, separate terms apply; see the section on data deletion below.</li>
        </ul>
      </section>

      <section class="legal__section" id="formaal">
        <h2>3. Purpose of processing</h2>
        <p>We process personal data for the following purposes:</p>
        <ul>
          <li>To answer inquiries and deliver our services</li>
          <li>To manage customer relationships and projects</li>
          <li>To improve the website, security, and user experience</li>
          <li>To comply with legal obligations</li>
        </ul>
        <p>
          We do not use your information for marketing without your consent, unless
          you are already a customer and we inform you about similar services — and
          you can always opt out.
        </p>
      </section>

      <section class="legal__section" id="retsgrundlag">
        <h2>4. Legal basis</h2>
        <p>We process personal data based on:</p>
        <ul>
          <li><strong>Performance of a contract</strong> — when processing is necessary to deliver an agreed service</li>
          <li><strong>Legitimate interest</strong> — e.g. operation and security of our website</li>
          <li><strong>Consent</strong> — where required, e.g. certain cookies</li>
          <li><strong>Legal obligation</strong> — when required by law</li>
        </ul>
      </section>

      <section class="legal__section" id="opbevaring">
        <h2>5. Retention</h2>
        <p>
          We retain personal data for as long as necessary for the purposes for
          which they were collected — typically as long as a customer relationship
          exists, plus the period required by law for accounting and documentation.
        </p>
        <p>
          Technical log data is retained for a shorter period unless it is necessary
          for security reasons.
        </p>
      </section>

      <section class="legal__section" id="deling">
        <h2>6. Sharing with third parties</h2>
        <p>
          We do not sell your personal data. We may share data with trusted
          data processors who assist us with operations — e.g. hosting, email, or
          analytics — under data processing agreements that ensure adequate protection.
        </p>
        <p>
          Information may also be disclosed if required by law or to protect our
          rights and safety.
        </p>
      </section>

      <section class="legal__section" id="sikkerhed">
        <h2>7. Security</h2>
        <p>
          We implement appropriate technical and organizational measures to
          protect personal data. However, no transfer over the internet is
          100% secure, and we cannot guarantee absolute security.
        </p>
      </section>

      <section class="legal__section" id="dine-rettigheder">
        <h2>8. Your rights</h2>
        <p>Under the GDPR, you have the right to:</p>
        <ul>
          <li>Access the information we hold about you</li>
          <li>Correct inaccurate information</li>
          <li>Have information deleted ("the right to be forgotten")</li>
          <li>Restrict or object to processing</li>
          <li>Receive your data in a structured format (data portability)</li>
          <li>Withdraw consent where processing is based on consent</li>
        </ul>
        <p>
          Contact us at <a href={`mailto:${contactEmail}`}>{contactEmail}</a> to
          exercise your rights. You can also lodge a complaint with the Danish Data
          Protection Agency (Datatilsynet).
        </p>
      </section>

      <section class="legal__section" id="datasletning">
        <h2>9. Deletion of app data</h2>
        <p>
          If you use one of our iOS or mobile apps, you can request the deletion of
          your account and associated data via our data deletion page:
        </p>
        <p>
          <a href={getLocaleLink("/data-sletning/", locale)}>Data Deletion Request</a>
        </p>
        <p>
          For the SMASH Padelcenter app, a dedicated page is available:
          <a href={getLocaleLink("/smash-padelcenter/data-sletning/", locale)}>Data Deletion (SMASH)</a>.
        </p>
        <p>
          You can also write directly to
          <a href={`mailto:${contactEmail}`}>{contactEmail}</a>.
        </p>
      </section>

      <section class="legal__section" id="cookies">
        <h2>10. Cookies and analytics</h2>
        <p>
          Our website may use cookies and similar technologies for operation,
          statistics, and improving the experience. You can manage cookies in your
          browser settings.
        </p>
        <p>
          We may use analytics tools (e.g. Google Analytics) to understand how the
          site is used. These tools may collect anonymized or pseudonymized usage
          data.
        </p>
      </section>

      <section class="legal__section" id="born">
        <h2>11. Children</h2>
        <p>
          Our services are not directed at persons under 13 years of age. We do not
          knowingly collect personal data from children. Contact us if you believe we
          have received such data.
        </p>
      </section>

      <section class="legal__section" id="links">
        <h2>12. Links to other websites</h2>
        <p>
          Our website may contain links to external sites. We are not responsible
          for the privacy practices of these sites. We recommend reading their
          privacy policies.
        </p>
      </section>

      <section class="legal__section" id="aendringer">
        <h2>13. Changes</h2>
        <p>
          We may update this privacy policy from time to time. Significant
          changes will be published on this page with an updated date. We encourage
          you to review the policy regularly.
        </p>
      </section>

      <section class="legal__section" id="kontakt">
        <h2>14. Contact</h2>
        <p>
          Questions about this privacy policy can be directed to:
        </p>
        <p>
          <strong>RNS-Apps ApS</strong><br />
          Email: <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
        </p>
      </section>
    </div>
  </article>

  <CinematicFooter />
</CinematicLayout>

<style>
  .legal {
    max-width: 42rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .legal__header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .legal__eyebrow {
    font-family: 'JUSTSans', system-ui, sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #ff6941;
    margin-bottom: 0.75rem;
  }

  .legal__title {
    font-family: 'Geszog', system-ui, sans-serif;
    font-size: clamp(2rem, 5vw, 2.75rem);
    line-height: 1.1;
    color: #fff;
    margin-bottom: 0.5rem;
  }

  .legal__meta {
    font-family: 'JUSTSans', system-ui, sans-serif;
    font-size: 0.9rem;
    color: #d1d5db;
    margin-bottom: 1.25rem;
  }

  .legal__intro {
    font-family: 'JUSTSans', system-ui, sans-serif;
    font-size: 1.05rem;
    line-height: 1.7;
    color: #d1d5db;
  }

  .legal__section {
    margin-bottom: 2.25rem;
  }

  .legal__section h2 {
    font-family: 'Quano', system-ui, sans-serif;
    font-size: 1.35rem;
    line-height: 1.25;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .legal__section p {
    font-family: 'JUSTSans', system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    color: #d1d5db;
    margin-bottom: 0.85rem;
  }

  .legal__section p:last-child {
    margin-bottom: 0;
  }

  .legal__section ul {
    margin: 0.5rem 0 1rem;
    padding-left: 1.25rem;
    list-style: disc;
  }

  .legal__section li {
    font-family: 'JUSTSans', system-ui, sans-serif;
    font-size: 1rem;
    line-height: 1.7;
    color: #d1d5db;
    margin-bottom: 0.5rem;
  }

  .legal__section li strong {
    color: #fff;
    font-weight: 600;
  }

  .legal__section a {
    color: #ff6941;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s ease;
  }

  .legal__section a:hover {
    color: #e05030;
  }
</style>
