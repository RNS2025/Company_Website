---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';

interface Props {
  title: string;
  summary: string;
  description: string;
  image: ImageMetadata;
  tags: string[];
  loading?: 'eager' | 'lazy';
  variant?: 'default' | 'cinematic';
  href?: string;
}

const {
  title,
  summary,
  description,
  image,
  tags,
  loading = 'lazy',
  variant = 'default',
  href
} = Astro.props;

const isCinematic = variant === 'cinematic';
const CardWrapper = href ? 'a' : 'div';
---

{isCinematic ? (
  <CardWrapper href={href} class="block h-full group text-left no-underline">
    <article class="cinematic-project-card h-full transition-all duration-300 group-hover:border-primary-500/30 group-hover:shadow-[0_0_30px_rgba(255,105,65,0.08)]">
      <div class="cinematic-project-card__media overflow-hidden">
        <Image
          src={image}
          alt=""
          loading={loading}
          class="cinematic-project-card__img transition-transform duration-500 group-hover:scale-105"
        />
      </div>
      <div class="cinematic-project-card__body">
        <p class="cinematic-project-card__summary">{summary}</p>
        <h3 class="cinematic-project-card__title group-hover:text-primary-500 transition-colors">{title}</h3>
        <p class="cinematic-project-card__desc">{description}</p>
        <div class="cinematic-project-card__tags">
          {tags.slice(0, 3).map((tag) => (
            <span class="cinematic-project-card__tag">{tag}</span>
          ))}
        </div>
      </div>
    </article>
  </CardWrapper>
) : (
  <CardWrapper href={href} class="block h-full group text-left no-underline">
    <Card class="overflow-hidden h-full transition-all duration-300 group-hover:border-primary-500/30">
      <div class="relative overflow-hidden aspect-video bg-white/5 flex items-center justify-center">
        <Image
          src={image}
          alt=""
          loading={loading}
          class="w-full h-full object-contain scale-75 p-4 transition-transform duration-500 group-hover:scale-80"
        />
      </div>

      <div class="p-6">
        <p class="text-xs font-semibold uppercase tracking-wider text-primary-500 mb-2">
          {summary}
        </p>
        <h3 class="text-xl font-bold text-white mb-3 group-hover:text-primary-500 transition-colors">
          {title}
        </h3>

        <p class="text-gray-300 leading-relaxed mb-4 text-sm">
          {description}
        </p>

        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <Badge>{tag}</Badge>
          ))}
        </div>
      </div>
    </Card>
  </CardWrapper>
)}
