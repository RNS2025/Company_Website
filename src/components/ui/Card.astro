---
interface Props {
    hover?: boolean | 'lift' | 'glow';
    glass?: boolean;
    class?: string;
}

const {
    hover = false,
    glass = false,
    class: className = ''
} = Astro.props;

const baseStyles = 'rounded-lg p-8';
const glassStyles = glass 
    ? 'bg-white/5 backdrop-blur-xl border border-white/10 text-white' 
    : 'bg-[#141312]/50 border border-white/10 backdrop-blur-xl shadow-lg text-white';
const hoverStyles = hover ? 'card-hover cursor-pointer transition-all duration-300 hover:border-primary-500/30' : '';

const classes = `${baseStyles} ${glassStyles} ${hoverStyles} ${className}`;
---

<div class={classes}>
    <slot />
</div>
