---
/**
 * StoryBlock — et genbrugeligt "kapitel" til scrollytelling-forsiden.
 *
 * Props:
 *   id          — anchor-id på sektionen
 *   align       — 'left' | 'center' | 'right'  (default: 'center')
 *   chapter     — kapitel-nummer vist som lille label øverst, fx "01"
 *   fullHeight  — fylder hele viewport-højden (default: true)
 *   class       — ekstra CSS-klasser på <section>
 *
 * Brug:
 *   <StoryBlock chapter="01" align="left">
 *     <h2>Overskrift</h2>
 *     <p>Tekst der fader ind linje for linje</p>
 *   </StoryBlock>
 *
 * Hvert direkte barn af blokken animerer ind med en lille forsinkelse
 * (staggered) når sektionen ruller ind i viewporten.
 */

interface Props {
    id?: string;
    align?: 'left' | 'center' | 'right';
    chapter?: string;
    fullHeight?: boolean;
    class?: string;
}

const {
    id,
    align = 'center',
    chapter,
    fullHeight = true,
    class: className = '',
} = Astro.props;

const alignMap = {
    left:   'items-start text-left',
    center: 'items-center text-center',
    right:  'items-end text-right',
};
---

<section
    id={id}
    class:list={[
        'story-block',
        'relative flex flex-col justify-center px-6 py-28',
        fullHeight ? 'h-svh' : '',
        alignMap[align],
        className,
    ]}
    data-story-block
>
    <div class="story-inner max-w-4xl w-full mx-auto">
        {chapter && (
            <p class="story-chapter-label">{chapter}</p>
        )}
        <slot />
    </div>
</section>

<style>
    /* ── Snap ──────────────────────────────────────────────── */
    .story-block {
        scroll-snap-align: start;
        scroll-snap-stop: always;
    }

    /* ── Kapitel-label: startposition ─────────────────────── */
    .story-chapter-label {
        font-family: 'JUSTSans', sans-serif;
        font-size: 0.75rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: #FF6941;
        margin-bottom: 1.5rem;
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.5s ease, transform 0.5s ease;
    }

    /* ── Børn: startposition (usynlig) ─────────────────────── */
    .story-inner > *:not(.story-chapter-label) {
        opacity: 0;
        transform: translateY(40px);
        transition:
            opacity 0.85s cubic-bezier(0.16, 1, 0.3, 1),
            transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* ── Synlig tilstand (klasse sat af JS) ─────────────────── */
    .story-block.is-entered .story-chapter-label,
    .story-block.is-entered .story-inner > *:not(.story-chapter-label) {
        opacity: 1;
        transform: translateY(0);
    }
</style>

<script>
    (() => {
        const init = () => {
            const blocks = document.querySelectorAll<HTMLElement>('[data-story-block]');

            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        const block = entry.target as HTMLElement;

                        if (entry.isIntersecting) {
                            // Sæt staggered forsinkelse på hvert barn
                            const children = Array.from(
                                block.querySelectorAll<HTMLElement>('.story-inner > *')
                            );
                            children.forEach((child, i) => {
                                child.style.transitionDelay = `${i * 0.18}s`;
                            });
                            // rAF sikrer at delay er sat inden klassen tilføjes
                            requestAnimationFrame(() => {
                                block.classList.add('is-entered');
                            });
                        } else {
                            // Nulstil klasse og delays mens sektionen er off-screen
                            block.classList.remove('is-entered');
                            block.querySelectorAll<HTMLElement>('.story-inner > *').forEach((child) => {
                                child.style.transitionDelay = '0s';
                            });
                        }
                    });
                },
                { threshold: 0.45 }
            );

            blocks.forEach((b) => observer.observe(b));
        };

        document.addEventListener('astro:page-load', init);
        if (document.readyState !== 'loading') init();
    })();
</script>
