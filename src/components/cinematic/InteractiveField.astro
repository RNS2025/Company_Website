---
// Antigravity Cosmic Ember River (Calm, Beautiful, Interactive)
---

<div class="interactive-field-container" aria-hidden="true" transition:persist="antigravity-bg">
  <canvas id="antigravity-vector-canvas"></canvas>
</div>

<style>
  .interactive-field-container {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: -20;
    pointer-events: none;
    background-color: #050505; /* Deep rich dark background */
  }
  #antigravity-vector-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>

<script is:inline>
(function() {
  if (window.__interactiveBgInitialized) return;
  window.__interactiveBgInitialized = true;

  const canvas = document.getElementById('antigravity-vector-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  
  let width, height;
  let particles = [];
  const numParticles = 160;
  
  let mouse = { x: -1000, y: -1000 };

  window.addEventListener('mousemove', (e) => {
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });

  window.addEventListener('mouseleave', () => {
    mouse.x = -1000;
    mouse.y = -1000;
  });

  function init() {
    width = canvas.width = window.innerWidth * window.devicePixelRatio;
    height = canvas.height = window.innerHeight * window.devicePixelRatio;
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    width = window.innerWidth;
    height = window.innerHeight;

    particles = [];
    for (let i = 0; i < numParticles; i++) {
      particles.push({
        x: Math.random() * width,
        y: Math.random() * height,
        z: Math.random() * 100 + 1, // Depth for parallax
        vx: (Math.random() - 0.5) * 0.05, // Almost still
        vy: (Math.random() - 0.5) * 0.05 - 0.02, // Very slight upward drift
        baseRadius: Math.random() * 1.5 + 0.5,
        // Range of warm firefly hues: deep red to bright amber (0 to 40)
        // Heavily weighted towards RNS Orange (15)
        hue: 15 + (Math.random() - 0.5) * 20, 
        phase: Math.random() * Math.PI * 2 // For twinkling
      });
    }
  }

  if (typeof ResizeObserver !== 'undefined') {
    new ResizeObserver(init).observe(document.body);
  } else {
    window.addEventListener('resize', init);
  }
  init();

  let time = 0;

  function animate() {
    // Clean background to remove heavy motion blur trails, but keep a slight fade
    ctx.fillStyle = 'rgba(5, 5, 5, 0.7)';
    ctx.fillRect(0, 0, width, height);
    time += 0.007; // Slower time

    // Sort particles by depth to draw back ones first
    particles.sort((a, b) => b.z - a.z);

    particles.forEach(p => {
      // Very gentle cosmic wind
      const windX = Math.sin(p.y * 0.005 + time) * 0.06;
      const windY = Math.cos(p.x * 0.005 + time) * 0.06;

      // Update position with velocity, wind, and parallax scaling
      const speedScale = 20 / p.z;
      p.x += (p.vx + windX) * speedScale;
      p.y += (p.vy + windY) * speedScale;

      // Mouse repulsion (Fluid parting effect)
      if (mouse.x > -100) {
        const dx = p.x - mouse.x;
        const dy = p.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const effectRadius = 250;

        if (dist < effectRadius && dist > 0) {
          const force = Math.pow((effectRadius - dist) / effectRadius, 2);
          // Push particles gently away
          p.x += (dx / dist) * force * 3 * speedScale;
          p.y += (dy / dist) * force * 3 * speedScale;
        }
      }

      // Wrap around screen gracefully
      if (p.x < -50) p.x = width + 50;
      if (p.x > width + 50) p.x = -50;
      if (p.y < -50) p.y = height + 50;
      if (p.y > height + 50) p.y = -50;

      // Render
      // Size depends on depth and baseRadius
      const size = p.baseRadius * (50 / p.z);
      
      // Twinkling effect
      const twinkle = Math.sin(time * 2 + p.phase) * 0.5 + 0.5; // 0 to 1
      
      // Calculate opacity and brightness
      // Deeper particles are darker and more transparent
      const depthAlpha = Math.max(0.1, 1 - (p.z / 100));
      const alpha = depthAlpha * (0.2 + 0.5 * twinkle); // Much lower opacity
      const brightness = 35 + 25 * twinkle; // Darker

      ctx.beginPath();
      ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
      
      // Soft glow
      ctx.fillStyle = `hsla(${p.hue}, 100%, ${brightness}%, ${alpha})`;
      ctx.shadowBlur = size * 3;
      ctx.shadowColor = `hsla(${p.hue}, 100%, 60%, ${alpha * 0.6})`;
      
      ctx.fill();
    });

    requestAnimationFrame(animate);
  }
  
  animate();
})();
</script>
