---
import { useTranslations, getLocaleLink } from '../../data/locales/i18n';

const locale = Astro.currentLocale || 'da';
const t = useTranslations(locale);
const { hero } = t;
---

<section class="cinematic-station" id="hero" data-cinematic-station>
  <div class="gradient-overlay" aria-hidden="true"></div>
  <div class="content">
    <p class="subtitle">{hero.subtitle}</p>
    {hero.proofLine && <p class="proof-line">{hero.proofLine}</p>}
    <h1>
      {hero.headlineBefore}
      <span class="highlight">{hero.headlineHighlight}</span>
      {hero.headlineAfter}
    </h1>
    <div class="ctas">
      <a class="cinematic-btn cinematic-btn--primary" href={getLocaleLink('/#kontakt', locale)}>
        {hero.ctaPrimary} <span aria-hidden="true">&rarr;</span>
      </a>
      <a class="cinematic-btn cinematic-btn--outline" href={getLocaleLink('/#projekter', locale)}>
        {hero.ctaSecondary}
      </a>
    </div>
  </div>
  <div class="bounce-arrow" aria-hidden="true">
    <span>{hero.scrollHint}</span>
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </div>
</section>
