---
/** Background video layer. Plays and loops naturally. */
---

<div id="scroll-video-container">
  <video
    id="video-fallback"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
    poster="/logo.png"
    aria-hidden="true"
    class="w-full h-full object-cover"
  >
    <source src="/video/hero-scroll.mp4" type="video/mp4" />
  </video>
  <div class="overlay" aria-hidden="true"></div>
</div>
